digraph ATM {
rankdir=TB

node [fontname="Arial"]

start [shape=oval label="Start"]

enterPin [shape=parallelogram label="Enter PIN"]
checkPin [shape=diamond label="PIN correct?"]

wrongPin [shape=box label="Incorrect PIN"]
checkAttempts [shape=diamond label="3 attempts used?"]
cardBlocked [shape=box label="Card blocked"]

enterAmount [shape=parallelogram label="Enter withdrawal amount"]

multiple20 [shape=diamond label="Multiple of 20 TL?"]
balanceCheck [shape=diamond label="Enough balance?"]
limitCheck [shape=diamond label="Daily limit exceeded?"]

takeCash [shape=box label="Dispense cash and update balance"]

another [shape=diamond label="Another transaction?"]

end [shape=oval label="End"]

start -> enterPin
enterPin -> checkPin

checkPin -> enterAmount [label="Yes"]
checkPin -> wrongPin [label="No"]

wrongPin -> checkAttempts
checkAttempts -> cardBlocked [label="Yes"]
checkAttempts -> enterPin [label="No"]

enterAmount -> multiple20

multiple20 -> enterAmount [label="No"]
multiple20 -> balanceCheck [label="Yes"]

balanceCheck -> enterAmount [label="No"]
balanceCheck -> limitCheck [label="Yes"]

limitCheck -> enterAmount [label="Yes"]
limitCheck -> takeCash [label="No"]

takeCash -> another

another -> enterAmount [label="Yes"]
another -> end [label="No"]

cardBlocked -> end
}
